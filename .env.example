PORT=3000

# Pixel MCP server (optional): Mem0 OSS (mem0ai/oss) — OPENAI_API_KEY for embedder + LLM
# pixel_get_context / pixel_store_memory — set in agent ./.cursor/mcp.json (or ./.claude/mcp.json) or here when testing
# OPENAI_API_KEY=
# Optional: SQLite history path for Mem0 OSS
# PIXEL_MEM0_HISTORY_DB=./.pixel-mem0-history.db
# Optional external Postgres URL; when omitted, backend uses embedded PGlite in `packages/backend/data`.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pixel_org
# Optional: root path for agent file storage (default: repo_root/agents).
# AGENTS_STORAGE_PATH=./agents
