PORT=3000
# Bind address (default 127.0.0.1 — localhost only). Use 0.0.0.0 to listen on all interfaces (e.g. Docker / LAN).
# HOST=127.0.0.1

# Self-healing agent (optional): POST 5xx / uncaught errors to the healer HTTP API (see packages/backend/src/healerClient.ts).
# HEALER_BASE_URL=<healer base URL>  ← scheme + host (optional port) only; `/error` and `/oauth/token` are appended by the client. Do not add /error or /oauth/token here or you will get paths like /error/error (default https://healer.garamm.dev).
# HEALER_REPO_SOURCE / HEALER_REPO_BRANCH are metadata only (repo to clone + branch for the fix PR). Omit either to disable reporting.
# HEALER_BASE_URL=https://healer.garamm.dev
# HEALER_REPO_SOURCE=https://github.com/ProblematicToucan/pixel-org.git
# HEALER_REPO_BRANCH=main
# If the healer has OAuth enabled, set client credentials for POST /oauth/token (then POST /error).
# HEALER_OAUTH_CLIENT_ID=
# HEALER_OAUTH_CLIENT_SECRET=

# Pixel MCP server (optional): Mem0 OSS (mem0ai/oss) — OPENAI_API_KEY for embedder + LLM
# pixel_get_context / pixel_store_memory — set in agent ./.cursor/mcp.json (or ./.claude/mcp.json) or here when testing
# OPENAI_API_KEY=
# Optional: SQLite history path for Mem0 OSS
# PIXEL_MEM0_HISTORY_DB=./.pixel-mem0-history.db
# Optional external Postgres URL; when omitted, backend uses embedded PGlite in `packages/backend/data`.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pixel_org
# Optional: root directory for agent workspaces (default: ~/.pixel-org).
# AGENTS_STORAGE_PATH=/custom/path
